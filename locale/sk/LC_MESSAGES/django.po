#: templates/policies/privacy_policy.html:74
msgid ""
"Stosujemy środki techniczne i organizacyjne (szyfrowanie SSL, regularne "
"aktualizacje, kontrola dostępu) aby chronić Twoje dane przed nieuprawnionym "
"dostępem, utratą lub uszkodzeniem."
msgstr ""
