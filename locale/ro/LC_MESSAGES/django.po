msgstr "– prezentul document."

#: templates/policies/regulamin.html:17
msgid "Sklep"
msgstr "Magazin"

#: templates/policies/regulamin.html:17
msgid "– serwis internetowy dostępny pod adresem"
msgstr "– site-ul web disponibil la adresa"

#: templates/policies/regulamin.html:17
