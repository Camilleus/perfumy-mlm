msgstr "Vânzător"

#: templates/policies/regulamin.html:18
msgid "prowadzący działalność nierejestrowaną pod nazwą „Przystanek Perfumy"
msgstr ""
"care desfășoară o activitate neînregistrată sub denumirea „Przystanek Perfumy"

#: templates/policies/regulamin.html:18
msgid "Warszawa."
msgstr "Varșovia."

#: templates/policies/regulamin.html:18
msgid "uzupełnij własnymi"
msgstr "completează cu datele tale"

#: templates/policies/regulamin.html:19
msgid "Klient"
msgstr "Client"

#: templates/policies/regulamin.html:19
msgid ""
"– osoba fizyczna (konsument) lub przedsiębiorca dokonujący zakupów w Sklepie."
msgstr ""
"– persoană fizică (consumator) sau antreprenor care efectuează achiziții în "
"Magazin."

#: templates/policies/regulamin.html:20
msgid "Kodeks cywilny"
msgstr "Codul civil"

#: templates/policies/regulamin.html:20
